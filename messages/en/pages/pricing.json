  "faq": {
    "title": "Any questions?",
    "description": "Contact our account managers if you don't find answers here",
    "items": [
      {
        "question": "Do I really get hundreds of apps at a single price?",
        "answer": "Yes. All Adon ERP apps are included in a single subscription fee for Standard and Professional plans. No module-level add-ons."
      },
      {
        "question": "What's included in the subscription?",
        "answer": "Hosting, maintenance, unlimited support, automatic upgrades, and updates for all apps are included."
      },
      {
        "question": "How does user-based pricing work?",
        "answer": "You pay based on the number of active users in your organization. You can increase or decrease user count at any time."
      },
      {
        "question": "Can I change my plan later?",
        "answer": "Absolutely. You can upgrade to a higher plan or change user count at any time. Downgrades take effect in the next billing cycle."
      },
      {
        "question": "What's the difference between yearly and monthly billing?",
        "answer": "Yearly billing saves you about 35% compared to monthly, 6-month billing saves about 20%, and quarterly billing saves about 10%. With yearly billing, you're billed once for the entire year."
      },
      {
        "question": "What payment methods do you support?",
        "answer": "We support bank transfer, bKash, Nagad, Rocket, and credit cards."
      }
    ]
  },

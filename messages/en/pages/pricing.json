    "faq": {
      "title": "Any questions?",
      "items": [
        {
          "question": "What's included in Success Packs?",
          "answer": "Each pack includes dedicated consultant hours, email & phone support, training & coaching, and configuration assistance — more advanced packs add customization, development, and on-site consulting."
        },
        {
          "question": "What does a dedicated customer success consultant do?",
          "answer": "Your consultant analyzes your business needs, configures the system, trains your team, imports your data, and customizes workflows to match how your business operates."
        },
        {
          "question": "What if I need custom development and integration?",
          "answer": "Standard, Custom, and Pro packs all include development hours. Your consultant will scope the work within your pack."
        },
        {
          "question": "What if I have performance issues?",
          "answer": "Standard, Custom, and Pro packs include performance issue support. Our consultants diagnose and resolve bottlenecks in your Odoo configuration."
        }
      ]
    }
